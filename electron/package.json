{
  "name": "thriveos",
  "version": "1.0.0",
  "description": "ThriveOS Desktop Browser — your AI-powered OS for life and business",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:macos": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:windows": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.thriveos.browser",
    "productName": "ThriveOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "build/**"
    ],
    "extraResources": [
      {
        "from": "out-static",
        "to": "out"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "ThriveOS.dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico",
      "artifactName": "ThriveOS_installer.exe"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.png",
      "category": "Network",
      "artifactName": "ThriveOS.AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    },
    "dmg": {
      "background": null,
      "backgroundColor": "#0f172a"
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1"
  }
}
